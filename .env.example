NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgres://cloudcommerce:cloudcommerce@localhost:5432/cloudcommerce
REDIS_URL=redis://localhost:6379
BETTER_AUTH_SECRET=change-me-change-me-change-me-change-me
COOKIE_SECRET=change-me-cookie-secret-change-me-cookie
MFA_SECRET_KEY=change-me-mfa-secret-change-me-mfa-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
TRUST_PROXY=false
LOG_LEVEL=info
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TOKEN=local-ai-token-change-me
AI_OPERATION_COST_LIMIT_MINOR=50000
AI_DAILY_ACTOR_COST_LIMIT_MINOR=500000
STRIPE_SECRET_KEY=change-me-stripe-secret-key
STRIPE_WEBHOOK_SECRET=change-me-stripe-webhook-secret
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MODO_API_KEY=
RESEND_API_KEY=change-me-resend-api-key
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=.cloudcommerce-media
MEDIA_MAX_FILE_BYTES=5242880
MEDIA_MAX_REQUEST_BYTES=31457280
RESERVATION_EXPIRATION_BATCH_SIZE=100
DOCUMENT_GENERATION_BATCH_SIZE=25
ORDER_FORWARD_BATCH_SIZE=20
ORDER_FORWARD_TIMEOUT_MS=15000
OWNER_EMAIL=owner@cloudcommerce.local
OWNER_PASSWORD=change-me-owner-password
OWNER_FULL_NAME=CloudCommerce Owner

# --- Frontends (apps/admin y apps/store) ---
# URL publica de la API que consumen los frontends via tRPC.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Servicio IA (apps/ai) ---
# Claves de los proveedores usados por el microservicio Python.
OPENAI_API_KEY=change-me-openai-api-key
GEMINI_API_KEY=change-me-gemini-api-key
# AI_SERVICE_TOKEN (definido arriba) es compartido: apps/api y apps/workers lo
# envian como Bearer y apps/ai lo valida.
# Modelos opcionales (si no se definen, apps/ai usa sus defaults).
OPENAI_TEXT_MODEL=
OPENAI_VISION_MODEL=
GEMINI_IMAGE_MODEL=

# --- Engagement (vendedor IA por WhatsApp) ---
# Nombre visible de la tienda en los mensajes generados.
STORE_NAME=CloudCommerce
# Credenciales de la Cloud API de WhatsApp (Meta). Si faltan, el envio queda
# deshabilitado y los workers de engagement no hacen nada.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token que Meta reenvia en la verificacion GET del webhook.
WHATSAPP_VERIFY_TOKEN=
# App secret de Meta: firma HMAC (X-Hub-Signature-256) del webhook entrante.
WHATSAPP_APP_SECRET=
# Dias minimos entre outreach automaticos a un mismo cliente.
ENGAGEMENT_OUTREACH_COOLDOWN_DAYS=7
