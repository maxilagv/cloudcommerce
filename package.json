{
  "name": "cloudcommerce",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @cloudcommerce/database db:generate",
    "db:migrate": "pnpm --filter @cloudcommerce/database db:migrate",
    "db:seed": "pnpm --filter @cloudcommerce/database db:seed"
  },
  "devDependencies": {
    "turbo": "2.10.0"
  }
}
