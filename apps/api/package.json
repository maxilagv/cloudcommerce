{
  "name": "@cloudcommerce/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./router": {
      "types": "./dist/interfaces/trpc/router.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@cloudcommerce/database": "workspace:*",
    "@cloudcommerce/trpc": "workspace:*",
    "@cloudcommerce/types": "workspace:*",
    "@cloudcommerce/validators": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@trpc/server": "^11.7.2",
    "argon2": "^0.44.0",
    "better-auth": "^1.3.34",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.6.2",
    "file-type": "^22.0.1",
    "ioredis": "^5.8.2",
    "otplib": "^12.0.1",
    "pino": "^10.1.0",
    "postgres": "^3.4.7",
    "sharp": "^0.35.3",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  }
}
