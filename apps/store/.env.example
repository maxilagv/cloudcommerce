# Base URL of the main API (apps/api, Fastify + tRPC). The store consumes
# `${NEXT_PUBLIC_API_URL}/trpc` and public images at `${NEXT_PUBLIC_API_URL}/media/public/{id}`.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Canonical public origin of the storefront (SEO: canonicals, sitemap, OG, JSON-LD).
# Set this to the real domain in production.
NEXT_PUBLIC_SITE_URL=https://www.cloudcommerce.com.ar
