# CloudCommerce AI Service

# Seguridad: token compartido con apps/api (mismo valor que AI_SERVICE_TOKEN del backend)
AI_SERVICE_TOKEN=change-me-min-16-chars

# OpenAI (ChatGPT): textos, especificaciones, SEO, análisis de imagen (visión), vendedor IA
OPENAI_API_KEY=change-me-openai-api-key
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o

# Gemini: creación y mejora de imágenes de producto
GEMINI_API_KEY=change-me-gemini-api-key
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Servicio
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
AI_SERVICE_ENV=development
AI_LOG_LEVEL=INFO

# Límites y costos (centavos ARS reportados a apps/api)
AI_MAX_IMAGE_BYTES=12582912
AI_IMAGE_OUTPUT_SIZE=2048
AI_TEXT_COST_MINOR_PER_1K_TOKENS=8
AI_IMAGE_COST_MINOR=5000

# Cache opcional
# REDIS_URL=redis://localhost:6379
AI_CACHE_TTL_SECONDS=3600
