# Copy this file to /opt/cloudcommerce-api/.env on the server. Never commit the real file.
POSTGRES_DB=cloudcommerce
POSTGRES_USER=cloudcommerce
POSTGRES_PASSWORD=replace-with-a-long-random-password

BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
COOKIE_SECRET=replace-with-at-least-32-random-characters
MFA_SECRET_KEY=replace-with-at-least-32-random-characters
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://cloudcommerce-api.173-249-11-196.sslip.io
TRUST_PROXY=true
LOG_LEVEL=info

# Integrations remain deliberately disabled until their real credentials are configured.
AI_SERVICE_URL=http://127.0.0.1:9999
AI_SERVICE_TOKEN=not-configured-use-a-real-token-before-enabling-ai
STRIPE_SECRET_KEY=not-configured
STRIPE_WEBHOOK_SECRET=not-configured
RESEND_API_KEY=not-configured
STORE_NAME=CloudCommerce
